{
  "version": 2,
  "functions": {
    "api/connector.py": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/connector.py" },
    { "src": "/api/start", "dest": "/api/connector.py" },
    { "src": "/api/process", "dest": "/api/connector.py" },
    { "src": "/api/docs", "dest": "/api/connector.py" },
    { "src": "/api/openapi.json", "dest": "/api/connector.py" }
  ]
}
